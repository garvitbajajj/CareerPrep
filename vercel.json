{
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "functions": {
    "api/[...path].js": {
      "includeFiles": "server/**"
    }
  }
}
